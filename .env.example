# Copy this file to `.env` in the same folder as docker-compose.yml and fill in real values.
# Docker Compose reads `.env` automatically for variable substitution — NOT `.env.example`.
# Never commit `.env` (it is gitignored).

APP_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
APP_JWT_SECRET_KEY=replace-with-long-random-secret-at-least-32-chars
